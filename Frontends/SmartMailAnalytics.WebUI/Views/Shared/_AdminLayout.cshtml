@{
    Layout = null;
}


<!DOCTYPE html>
<html lang="tr" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark light" />
    <title>Mail Yönetim Paneli — Dashboard</title>
    <link rel="stylesheet" href="/Dashboard/css/variables.css" />
    <link rel="stylesheet" href="/Dashboard/css/base.css" />
    <link rel="stylesheet" href="/Dashboard/css/dashboard.css" />
</head>
<body>
    <div class="app">
        <aside class="sidebar" aria-label="Ana menü">
            <div class="sidebar__brand">
                <div class="sidebar__logo" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M4 6h16v12H4V6zm2 0 6 5 6-5"
                              stroke="currentColor"
                              stroke-width="1.75"
                              stroke-linecap="round"
                              stroke-linejoin="round" />
                    </svg>
                </div>
                <div>
                    <div class="sidebar__title">Smart Mail Analytics</div>
                    <div class="sidebar__subtitle">Yönetim konsolu</div>
                </div>
            </div>

            <nav aria-label="Bölümler">
                <div class="nav-section">
                    <div class="nav-section__label">Genel</div>
                    <ul class="nav-list">
                        <li>
                            <a class="nav-link nav-link--active" href="/Dashboard/Index/" aria-current="page">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                    <path d="M4 10.5 12 4l8 6.5V20a1 1 0 0 1-1 1h-5v-6H10v6H5a1 1 0 0 1-1-1v-9.5Z"
                                          stroke="currentColor"
                                          stroke-width="1.6"
                                          stroke-linejoin="round" />
                                </svg>
                                Dashboard
                            </a>
                        </li>
                        <li>
                            <a class="nav-link" href="/Mail/MailList">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                    <path d="M4 6h16v12H4V6zm0 3 8 5 8-5"
                                          stroke="currentColor"
                                          stroke-width="1.6"
                                          stroke-linecap="round"
                                          stroke-linejoin="round" />
                                </svg>
                                Mails
                            </a>
                        </li>
                        <li>
                            <a class="nav-link" href="/User/UserList">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z"
                                          stroke="currentColor"
                                          stroke-width="1.6"
                                          stroke-linecap="round"
                                          stroke-linejoin="round" />
                                </svg>
                                Kullanıcılar
                            </a>
                        </li>
                        <li>
                            <a class="nav-link" href="/MailCategory/MailCategoryList">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                    <path d="M4 6h16M4 12h10M4 18h16"
                                          stroke="currentColor"
                                          stroke-width="1.6"
                                          stroke-linecap="round" />
                                </svg>
                                Kategoriler
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>
        </aside>

        <div class="main">
            <header class="header">
                <div class="header__left">
                    <div>
                        <h1 class="header__title">Yönetici Dashboard</h1>
                        <p class="header__meta">Son güncelleme: <span data-static-date>—</span></p>
                    </div>
                </div>
                <div class="header__actions">
                    <button type="button" class="icon-btn" id="theme-toggle" title="Tema değiştir">
                        <span class="visually-hidden">Açık / koyu tema</span>
                        <svg id="icon-theme" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                            <path d="M12 3a9 9 0 1 0 9 9 7 7 0 0 1-9-9Z"
                                  stroke="currentColor"
                                  stroke-width="1.6"
                                  stroke-linecap="round"
                                  stroke-linejoin="round" />
                        </svg>
                    </button>
                </div>
            </header>

            @RenderBody()

        </div>
    </div>

    <script src="/Dashboard/js/app.js" defer></script>
</body>
</html>



