@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}



<main class="content">
    <section class="kpi-grid" aria-label="Özet KPI">
        <article class="kpi-card">
            <div class="kpi-card__top">
                <span class="kpi-card__label">Gelen posta (24s)</span>
                <span class="kpi-card__icon kpi-card__icon--accent" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                        <path d="M4 6h16v12H4V6zm0 3 8 5 8-5"
                              stroke="currentColor"
                              stroke-width="1.6"
                              stroke-linecap="round"
                              stroke-linejoin="round" />
                    </svg>
                </span>
            </div>
            <div class="kpi-card__value">12.458</div>
            <div class="kpi-card__delta"><strong>+6.2%</strong> dün ile kıyas</div>
        </article>

        <article class="kpi-card">
            <div class="kpi-card__top">
                <span class="kpi-card__label">Teslim edilen</span>
                <span class="kpi-card__icon kpi-card__icon--positive" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                        <path d="m20 7-9 9-4-4"
                              stroke="currentColor"
                              stroke-width="1.75"
                              stroke-linecap="round"
                              stroke-linejoin="round" />
                    </svg>
                </span>
            </div>
            <div class="kpi-card__value">11.892</div>
            <div class="kpi-card__delta"><strong>98.2%</strong> teslim oranı</div>
        </article>

        <article class="kpi-card">
            <div class="kpi-card__top">
                <span class="kpi-card__label">Karantina / spam</span>
                <span class="kpi-card__icon kpi-card__icon--warning" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                        <path d="M12 9v4m0 4h.01M5.07 19h13.86a2 2 0 0 0 1.74-3l-6.93-12a2 2 0 0 0-3.48 0l-6.93 12a2 2 0 0 0 1.74 3Z"
                              stroke="currentColor"
                              stroke-width="1.5"
                              stroke-linecap="round"
                              stroke-linejoin="round" />
                    </svg>
                </span>
            </div>
            <div class="kpi-card__value">342</div>
            <div class="kpi-card__delta"><strong class="negative">−1.1%</strong> yanlış pozitif</div>
        </article>

        <article class="kpi-card">
            <div class="kpi-card__top">
                <span class="kpi-card__label">Bounce / geri dönüş</span>
                <span class="kpi-card__icon kpi-card__icon--danger" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                        <path d="M12 19V5M5 12l7-7 7 7"
                              stroke="currentColor"
                              stroke-width="1.6"
                              stroke-linecap="round"
                              stroke-linejoin="round" />
                    </svg>
                </span>
            </div>
            <div class="kpi-card__value">224</div>
            <div class="kpi-card__delta">Hard <strong>62</strong> · Soft <strong>162</strong></div>
        </article>
    </section>

    <div class="dash-grid">
        <section class="panel" aria-labelledby="chart-volume-title">
            <div class="panel__head">
                <div>
                    <h2 id="chart-volume-title" class="panel__title">Haftalık posta hacmi</h2>
                    <p class="panel__desc">Inbound + outbound birleşik (örnek veri)</p>
                </div>
                <span class="badge badge--live">Canlıya hazır</span>
            </div>

            <div class="chart-bars" role="img" aria-label="Son 7 gün hacim grafik çubukları">
                <div class="chart-bar-wrap">
                    <div class="chart-bar" style="height: 52%"></div>
                    <span class="chart-bar-label">Pzt</span>
                </div>
                <div class="chart-bar-wrap">
                    <div class="chart-bar" style="height: 68%"></div>
                    <span class="chart-bar-label">Sal</span>
                </div>
                <div class="chart-bar-wrap">
                    <div class="chart-bar" style="height: 61%"></div>
                    <span class="chart-bar-label">Çar</span>
                </div>
                <div class="chart-bar-wrap">
                    <div class="chart-bar" style="height: 92%"></div>
                    <span class="chart-bar-label">Per</span>
                </div>
                <div class="chart-bar-wrap">
                    <div class="chart-bar" style="height: 74%"></div>
                    <span class="chart-bar-label">Cum</span>
                </div>
                <div class="chart-bar-wrap">
                    <div class="chart-bar" style="height: 38%"></div>
                    <span class="chart-bar-label">Cmt</span>
                </div>
                <div class="chart-bar-wrap">
                    <div class="chart-bar" style="height: 44%"></div>
                    <span class="chart-bar-label">Paz</span>
                </div>
            </div>
        </section>

        <section class="panel" aria-labelledby="delivery-title">
            <div class="panel__head">
                <div>
                    <h2 id="delivery-title" class="panel__title">İletim sonuçları</h2>
                    <p class="panel__desc">Son 24 saatte işlenen mesajların dağılımı</p>
                </div>
            </div>

            <div class="delivery-chart">
                <div class="delivery-row">
                    <div>
                        <div class="stacked-bar" role="img" aria-label="%84.8 teslim, %11.2 ertelenmiş, %4 başarısız">
                            <div class="stacked-bar__seg stacked-bar__seg--ok"></div>
                            <div class="stacked-bar__seg stacked-bar__seg--defer"></div>
                            <div class="stacked-bar__seg stacked-bar__seg--fail"></div>
                        </div>
                        <p class="delivery-chart__cap">
                            Ortalama kuyruk bekleme süresi <strong>1.4 sn</strong>
                        </p>
                    </div>
                    <div class="legend" aria-hidden="true">
                        <div class="legend__item">
                            <span class="legend__dot legend__dot--ok"></span>
                            Teslim
                            <span class="legend__strong">84.8%</span>
                        </div>
                        <div class="legend__item">
                            <span class="legend__dot legend__dot--defer"></span>
                            Erteleme / greylisting
                            <span class="legend__strong">11.2%</span>
                        </div>
                        <div class="legend__item">
                            <span class="legend__dot legend__dot--fail"></span>
                            Kalıcı başarısız
                            <span class="legend__strong">4.0%</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>

    <div class="dash-grid dash-grid--secondary">
        <section class="panel spark-panel" aria-labelledby="throughput-title">
            <div class="panel__head">
                <div>
                    <h2 id="throughput-title" class="panel__title">Throughput &amp; gecikme</h2>
                    <p class="panel__desc">Statik sparkline — .NET ile gerçek zamanlı beslenebilir</p>
                </div>
            </div>

            <div class="mini-stats">
                <div class="mini-stat">
                    <div class="mini-stat__label">Saniyede işlenen</div>
                    <div class="mini-stat__value">428 msg/s</div>
                </div>
                <div class="mini-stat">
                    <div class="mini-stat__label">p95 gecikme</div>
                    <div class="mini-stat__value">312 ms</div>
                </div>
                <div class="mini-stat">
                    <div class="mini-stat__label">Kuyruk derinliği</div>
                    <div class="mini-stat__value">1.842</div>
                </div>
            </div>

            <svg class="spark-svg"
                 viewBox="0 0 400 120"
                 preserveAspectRatio="none"
                 role="img"
                 aria-label="Örnek throughput eğrisi">
                <defs>
                    <linearGradient id="sparkFill" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="rgb(56 189 248)" stop-opacity="0.35" />
                        <stop offset="100%" stop-color="rgb(56 189 248)" stop-opacity="0" />
                    </linearGradient>
                </defs>
                <path class="spark-area"
                      d="M0,95 L40,88 L80,72 L120,78 L160,52 L200,60 L240,38 L280,48 L320,28 L360,42 L400,22 L400,120 L0,120 Z"
                      fill="url(#sparkFill)" />
                <path class="spark-path"
                      d="M0,95 L40,88 L80,72 L120,78 L160,52 L200,60 L240,38 L280,48 L320,28 L360,42 L400,22" />
            </svg>
        </section>

        <section class="panel" aria-labelledby="recent-title">
            <div class="panel__head">
                <div>
                    <h2 id="recent-title" class="panel__title">Son olaylar</h2>
                    <p class="panel__desc">SMTP olayları ve yönlendirme kayıtları</p>
                </div>
            </div>
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Zaman</th>
                            <th>Olay</th>
                            <th>Gönderen</th>
                            <th>Durum</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="mono">10:42:18</td>
                            <td>accepted</td>
                            <td class="mono">billing@acme.test</td>
                            <td><span class="pill pill--success">250 OK</span></td>
                        </tr>
                        <tr>
                            <td class="mono">10:41:03</td>
                            <td>defer</td>
                            <td class="mono">notify@partner.test</td>
                            <td><span class="pill pill--warn">451 4.7.1</span></td>
                        </tr>
                        <tr>
                            <td class="mono">10:39:51</td>
                            <td>dkim_fail</td>
                            <td class="mono">news@unknown.test</td>
                            <td><span class="pill pill--warn">quarantine</span></td>
                        </tr>
                        <tr>
                            <td class="mono">10:38:22</td>
                            <td>bounced</td>
                            <td class="mono">no-reply@svc.test</td>
                            <td><span class="pill pill--err">550 5.1.1</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>
    </div>


</main>




