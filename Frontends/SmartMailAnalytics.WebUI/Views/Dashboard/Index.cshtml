@using System.Globalization
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var mailTotal = (int)ViewBag.MailCount;
    var mailWeek = (int)ViewBag.MailCountWeek;
    var users = (int)ViewBag.UserCount;
    var tr = CultureInfo.GetCultureInfo("tr-TR");

    double[] w = { 0.82, 1.05, 0.93, 1.12, 0.88, 0.79, 1.01 };
    var sumW = w.Sum();
    var dayShares = w.Select(x => mailWeek * x / sumW).ToArray();
    var peak = dayShares.Max();

    var weekLabels = new string[7];
    for (var i = 0; i < 7; i++)
    {
        var d = DateTime.Today.AddDays(-6 + i);
        weekLabels[i] = d.ToString("ddd", tr);
    }

    var olderMail = mailTotal - mailWeek;
    var pctOlderBar = 100.0 * olderMail / mailTotal;
    var pctRecentBar = 100.0 * mailWeek / mailTotal;
    var weekRatioLabel = (100.0 * mailWeek / mailTotal).ToString("F4", tr);

    var sparkLine = new System.Text.StringBuilder();
    for (var i = 0; i < 7; i++)
    {
        var x = i * 400.0 / 6.0;
        var y = 120 - (dayShares[i] / peak * 88 + 12);
        var xs = x.ToString("F1", CultureInfo.InvariantCulture);
        var ys = y.ToString("F1", CultureInfo.InvariantCulture);
        sparkLine.Append(i == 0 ? "M" + xs + "," + ys : " L" + xs + "," + ys);
    }

    var sparkLinePath = sparkLine.ToString();
    var sparkAreaPath = sparkLinePath + " L400,120 L0,120 Z";
}

<main class="content">
    <section class="kpi-grid" aria-label="Özet KPI">
        <article class="kpi-card">
            <div class="kpi-card__top">
                <span class="kpi-card__label">Toplam posta</span>
                <span class="kpi-card__icon kpi-card__icon--accent" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                        <path d="M4 6h16v12H4V6zm0 3 8 5 8-5"
                              stroke="currentColor"
                              stroke-width="1.6"
                              stroke-linecap="round"
                              stroke-linejoin="round" />
                    </svg>
                </span>
            </div>
            <div class="kpi-card__value">@mailTotal.ToString("N0", tr)</div>
            <div class="kpi-card__delta"><strong>GetMailCount</strong> · tüm kayıtlar</div>
        </article>

        <article class="kpi-card">
            <div class="kpi-card__top">
                <span class="kpi-card__label">Son 7 gün</span>
                <span class="kpi-card__icon kpi-card__icon--positive" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                        <path d="m20 7-9 9-4-4"
                              stroke="currentColor"
                              stroke-width="1.75"
                              stroke-linecap="round"
                              stroke-linejoin="round" />
                    </svg>
                </span>
            </div>
            <div class="kpi-card__value">@mailWeek.ToString("N0", tr)</div>
            <div class="kpi-card__delta"><strong>GetMailCountByDate</strong></div>
        </article>

        <article class="kpi-card">
            <div class="kpi-card__top">
                <span class="kpi-card__label">Kullanıcılar</span>
                <span class="kpi-card__icon kpi-card__icon--warning" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z"
                              stroke="currentColor"
                              stroke-width="1.6"
                              stroke-linecap="round"
                              stroke-linejoin="round" />
                    </svg>
                </span>
            </div>
            <div class="kpi-card__value">@users.ToString("N0", tr)</div>
            <div class="kpi-card__delta"><strong>GetUserCount</strong></div>
        </article>

        <article class="kpi-card">
            <div class="kpi-card__top">
                <span class="kpi-card__label">Haftalık / toplam</span>
                <span class="kpi-card__icon kpi-card__icon--danger" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                        <path d="M12 19V5M5 12l7-7 7 7"
                              stroke="currentColor"
                              stroke-width="1.6"
                              stroke-linecap="round"
                              stroke-linejoin="round" />
                    </svg>
                </span>
            </div>
            <div class="kpi-card__value">@weekRatioLabel&nbsp;%</div>
            <div class="kpi-card__delta">Son 7 günün toplama oranı</div>
        </article>
    </section>

    <div class="dash-grid">
        <section class="panel" aria-labelledby="chart-volume-title">
            <div class="panel__head">
                <div>
                    <h2 id="chart-volume-title" class="panel__title">Haftalık posta hacmi</h2>
                    <p class="panel__desc">Son 7 gün toplamı @mailWeek.ToString("N0", tr) — çubuklar tahmini günlük dağılım</p>
                </div>
                <span class="badge badge--live">Canlıya hazır</span>
            </div>

            <div class="chart-bars" role="img" aria-label="Son 7 gün hacim grafik çubukları">
                @for (var i = 0; i < 7; i++)
                {
                    var pct = dayShares[i] / peak * 100.0;
                    <div class="chart-bar-wrap">
                        <div class="chart-bar" style="height: @(pct.ToString("F1", CultureInfo.InvariantCulture))%"></div>
                        <span class="chart-bar-label">@weekLabels[i]</span>
                    </div>
                }
            </div>
        </section>

        <section class="panel" aria-labelledby="mix-title">
            <div class="panel__head">
                <div>
                    <h2 id="mix-title" class="panel__title">Posta zaman karışımı</h2>
                    <p class="panel__desc">Toplam posta içinde son 7 günlük dilim · GetMailCount + GetMailCountByDate</p>
                </div>
            </div>

            <div class="delivery-chart">
                <div class="delivery-row">
                    <div>
                        <div class="stacked-bar" role="img" aria-label="Posta yaş dağılımı">
                            <div class="stacked-bar__seg stacked-bar__seg--ok stacked-bar__seg--live"
                                 style="width: @(pctOlderBar.ToString("F2", CultureInfo.InvariantCulture))%"></div>
                            <div class="stacked-bar__seg stacked-bar__seg--defer stacked-bar__seg--live"
                                 style="width: @(pctRecentBar.ToString("F2", CultureInfo.InvariantCulture))%"></div>
                        </div>
                        <p class="delivery-chart__cap">
                            7 günden eski kayıt <strong>@olderMail.ToString("N0", tr)</strong>
                            · son 7 gün <strong>@mailWeek.ToString("N0", tr)</strong>
                        </p>
                    </div>
                    <div class="legend" aria-hidden="true">
                        <div class="legend__item">
                            <span class="legend__dot legend__dot--ok"></span>
                            Arşiv (&gt;7 gün)
                            <span class="legend__strong">@pctOlderBar.ToString("F1", tr)&nbsp;%</span>
                        </div>
                        <div class="legend__item">
                            <span class="legend__dot legend__dot--defer"></span>
                            Son 7 gün
                            <span class="legend__strong">@pctRecentBar.ToString("F1", tr)&nbsp;%</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>

    <div class="dash-grid dash-grid--secondary">
        <section class="panel spark-panel" aria-labelledby="throughput-title">
            <div class="panel__head">
                <div>
                    <h2 id="throughput-title" class="panel__title">Haftalık trend çizgisi</h2>
                    <p class="panel__desc">Son 7 gün toplamından üretilen günlük tahmini dağılım · GetMailCountByDate</p>
                </div>
            </div>

            <div class="mini-stats">
                <div class="mini-stat">
                    <div class="mini-stat__label">Toplam posta</div>
                    <div class="mini-stat__value">@mailTotal.ToString("N0", tr)</div>
                </div>
                <div class="mini-stat">
                    <div class="mini-stat__label">Son 7 gün</div>
                    <div class="mini-stat__value">@mailWeek.ToString("N0", tr)</div>
                </div>
                <div class="mini-stat">
                    <div class="mini-stat__label">Kullanıcı</div>
                    <div class="mini-stat__value">@users.ToString("N0", tr)</div>
                </div>
            </div>

            <svg class="spark-svg"
                 viewBox="0 0 400 120"
                 preserveAspectRatio="none"
                 role="img"
                 aria-label="Son 7 gün tahmini günlük dağılım eğrisi">
                <defs>
                    <linearGradient id="sparkFill" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="rgb(56 189 248)" stop-opacity="0.35" />
                        <stop offset="100%" stop-color="rgb(56 189 248)" stop-opacity="0" />
                    </linearGradient>
                </defs>
                <path class="spark-area"
                      d="@sparkAreaPath"
                      fill="url(#sparkFill)" />
                <path class="spark-path"
                      d="@sparkLinePath" />
            </svg>
        </section>

        <section class="panel" aria-labelledby="modules-title">
            <div class="panel__head">
                <div>
                    <h2 id="modules-title" class="panel__title">Modüller</h2>
                    <p class="panel__desc">SmartMailAnalytics WebUI sayfalarına git</p>
                </div>
            </div>
            <nav class="quick-links" aria-label="Modül bağlantıları">
                <a href="/Mail/MailList">
                    Postalar
                    <span>Listele · oluştur · güncelle</span>
                </a>
                <a href="/User/UserList">
                    Kullanıcılar
                    <span>GetUserCount ile uyumlu liste</span>
                </a>
                <a href="/MailCategory/MailCategoryList">
                    Kategoriler
                    <span>Mail sınıfları</span>
                </a>
            </nav>
        </section>
    </div>


</main>




