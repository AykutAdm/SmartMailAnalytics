@model List<ResultMailDto>
@{
    ViewData["Title"] = "MailList";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<style>
    @@import url('https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap');

    :root {
        --bg: #0d0f14;
        --surface: #13161e;
        --surface-2: #1a1e2a;
        --border: #252a38;
        --border-hover: #363d52;
        --accent: #4f8ef7;
        --accent-glow: rgba(79,142,247,0.15);
        --accent-soft: rgba(79,142,247,0.08);
        --spam: #f7584f;
        --spam-soft: rgba(247,88,79,0.10);
        --green: #3ecf8e;
        --green-soft: rgba(62,207,142,0.10);
        --muted: #4a5168;
        --text: #e2e6f0;
        --text-sub: #7b849c;
        --radius: 14px;
        --radius-sm: 8px;
    }

    .mail-page {
        font-family: 'Sora', sans-serif;
        background: var(--bg);
        min-height: 100vh;
        padding: 36px 28px 60px;
        color: var(--text);
    }

    /* ── Header ── */
    .mail-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 32px;
        gap: 20px;
        flex-wrap: wrap;
    }

    .mail-header-left h1 {
        font-size: 22px;
        font-weight: 600;
        letter-spacing: -0.3px;
        margin: 0 0 4px;
        color: var(--text);
    }

    .mail-header-left p {
        font-size: 13px;
        color: var(--text-sub);
        margin: 0;
        font-weight: 300;
    }

    .badge-count {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--accent-soft);
        border: 1px solid rgba(79,142,247,0.25);
        color: var(--accent);
        font-size: 12px;
        font-weight: 500;
        padding: 3px 10px;
        border-radius: 20px;
        margin-left: 10px;
        vertical-align: middle;
        font-family: 'JetBrains Mono', monospace;
    }

    /* ── Filter Bar ── */
    .filter-bar {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .filter-btn {
        padding: 7px 16px;
        border-radius: 20px;
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--text-sub);
        font-size: 12.5px;
        font-family: 'Sora', sans-serif;
        cursor: pointer;
        transition: all .18s;
        font-weight: 400;
    }

        .filter-btn:hover, .filter-btn.active {
            border-color: var(--accent);
            color: var(--accent);
            background: var(--accent-soft);
        }

        .filter-btn.spam-btn:hover, .filter-btn.spam-btn.active {
            border-color: var(--spam);
            color: var(--spam);
            background: var(--spam-soft);
        }

    /* ── Search ── */
    .search-wrap {
        position: relative;
        flex: 1;
        min-width: 200px;
        max-width: 320px;
    }

        .search-wrap svg {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            pointer-events: none;
        }

    .search-input {
        width: 100%;
        padding: 8px 14px 8px 36px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 20px;
        color: var(--text);
        font-size: 13px;
        font-family: 'Sora', sans-serif;
        outline: none;
        transition: border-color .18s;
        box-sizing: border-box;
    }

        .search-input:focus {
            border-color: var(--accent);
        }

        .search-input::placeholder {
            color: var(--muted);
        }

    /* ── Table Card ── */
    .mail-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
    }

    /* ── Table ── */
    .mail-table {
        width: 100%;
        border-collapse: collapse;
    }

        .mail-table thead tr {
            border-bottom: 1px solid var(--border);
        }

        .mail-table th {
            padding: 13px 18px;
            text-align: left;
            font-size: 11.5px;
            font-weight: 500;
            color: var(--text-sub);
            letter-spacing: 0.6px;
            text-transform: uppercase;
            background: var(--surface-2);
            white-space: nowrap;
            user-select: none;
        }

            .mail-table th:first-child {
                padding-left: 22px;
            }

            .mail-table th:last-child {
                padding-right: 22px;
                text-align: right;
            }

        /* ── Rows ── */
        .mail-table tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background .15s;
            cursor: pointer;
        }

            .mail-table tbody tr:last-child {
                border-bottom: none;
            }

            .mail-table tbody tr:hover {
                background: var(--surface-2);
            }

        .mail-table td {
            padding: 14px 18px;
            font-size: 13.5px;
            color: var(--text);
            vertical-align: middle;
        }

            .mail-table td:first-child {
                padding-left: 22px;
            }

            .mail-table td:last-child {
                padding-right: 22px;
                text-align: right;
            }

    /* ── ID chip ── */
    .id-chip {
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px;
        color: var(--text-sub);
        background: var(--surface-2);
        border: 1px solid var(--border);
        padding: 2px 8px;
        border-radius: 6px;
    }

    /* ── Avatar + Email ── */
    .email-cell {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .avatar {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 600;
        flex-shrink: 0;
        color: #fff;
    }

    .email-text {
        font-size: 13px;
        color: var(--text);
    }

    /* ── Subject ── */
    .subject-text {
        max-width: 220px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-weight: 400;
        color: var(--text);
    }

    /* ── Category chip ── */
    .cat-chip {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 11.5px;
        font-weight: 500;
        background: var(--surface-2);
        border: 1px solid var(--border);
        color: var(--text-sub);
        white-space: nowrap;
    }

    /* ── Spam badge ── */
    .spam-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 11.5px;
        font-weight: 500;
    }

        .spam-badge.is-spam {
            background: var(--spam-soft);
            border: 1px solid rgba(247,88,79,0.25);
            color: var(--spam);
        }

        .spam-badge.not-spam {
            background: var(--green-soft);
            border: 1px solid rgba(62,207,142,0.25);
            color: var(--green);
        }

        .spam-badge::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: currentColor;
            display: inline-block;
        }

    /* ── Date ── */
    .date-text {
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px;
        color: var(--text-sub);
        white-space: nowrap;
    }

    /* ── Action Buttons ── */
    .action-wrap {
        display: flex;
        gap: 6px;
        justify-content: flex-end;
    }

    .action-btn {
        width: 30px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: var(--radius-sm);
        border: 1px solid var(--border);
        background: transparent;
        color: var(--muted);
        cursor: pointer;
        transition: all .15s;
        text-decoration: none;
    }

        .action-btn:hover {
            border-color: var(--accent);
            color: var(--accent);
            background: var(--accent-soft);
        }

        .action-btn.del:hover {
            border-color: var(--spam);
            color: var(--spam);
            background: var(--spam-soft);
        }

    /* ── Empty State ── */
    .empty-row td {
        text-align: center;
        padding: 60px 20px;
        color: var(--text-sub);
        font-size: 14px;
    }

    /* ── Footer ── */
    .mail-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 22px;
        border-top: 1px solid var(--border);
        font-size: 12px;
        color: var(--text-sub);
        flex-wrap: wrap;
        gap: 10px;
    }

    .page-info {
        font-family: 'JetBrains Mono', monospace;
    }

    .pager {
        display: flex;
        align-items: center;
        gap: 14px;
        font-family: 'JetBrains Mono', monospace;
    }

        .pager a {
            color: var(--accent);
            text-decoration: none;
            font-size: 12px;
        }

            .pager a:hover {
                text-decoration: underline;
            }

        .pager span {
            color: var(--text-sub);
            font-size: 12px;
        }
</style>

<div class="mail-page">

    <!-- Header -->
    <div class="mail-header">
        <div class="mail-header-left">
            <h1>
                Mail Kutusu
                <span class="badge-count">@Model.Count</span>
            </h1>
            <p>Tüm gelen ve giden mailler</p>
        </div>

        <div class="filter-bar">
            <form method="get" asp-action="MailList" style="display: contents;">
                <input type="hidden" name="spam" value="@ViewBag.Spam" />
                <input type="hidden" name="page" value="1" />
                <div class="search-wrap">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="11" cy="11" r="8" />
                        <path d="m21 21-4.35-4.35" />
                    </svg>
                    <input type="text" name="q" class="search-input" value="@ViewBag.Q" placeholder="Konu veya e-posta ara..." />
                </div>
            </form>

            <a href="@Url.Action("MailList", "Mail", new { page = 1, q = ViewBag.Q, spam = "all" })" class="filter-btn @(ViewBag.Spam as string == "all" ? "active" : "")">Tümü</a>
            <a href="@Url.Action("MailList", "Mail", new { page = 1, q = ViewBag.Q, spam = "spam" })" class="filter-btn spam-btn @(ViewBag.Spam as string == "spam" ? "active" : "")">Spam</a>
            <a href="@Url.Action("MailList", "Mail", new { page = 1, q = ViewBag.Q, spam = "clean" })" class="filter-btn @(ViewBag.Spam as string == "clean" ? "active" : "")">Temiz</a>

            <a href="/Mail/CreateMail" class="filter-btn" style="text-decoration:none; background:var(--accent-soft); border-color:rgba(79,142,247,0.35); color:var(--accent);">
                + Yeni Mail
            </a>
        </div>
    </div>

    <!-- Table Card -->
    <div class="mail-card">
        <table class="mail-table" id="mailTable">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Gönderen</th>
                    <th>Alıcı</th>
                    <th>Konu</th>
                    <th>Kategori</th>
                    <th>Durum</th>
                    <th>Tarih</th>
                    <th>İşlem</th>
                </tr>
            </thead>
            <tbody id="mailBody">
                @foreach (var item in Model)
                {
                    var avatarColors = new[] { "#4f8ef7", "#a855f7", "#3ecf8e", "#f7584f", "#f59e0b", "#06b6d4" };
                    var colorIndex = Math.Abs(item.SenderEmail.GetHashCode()) % avatarColors.Length;
                    var avatarColor = avatarColors[colorIndex];
                    var initial = item.SenderEmail.Length > 0 ? item.SenderEmail[0].ToString().ToUpper() : "?";

                    <tr data-spam="@item.IsSpam.ToString().ToLower()"
                        data-search="@item.SenderEmail @item.ReceiverEmail @item.Subject">
                        <!-- ID -->
                        <td><span class="id-chip">@item.MailId</span></td>

                        <!-- Sender -->
                        <td>
                            <div class="email-cell">
                                <div class="avatar" style="background:@avatarColor">@initial</div>
                                <span class="email-text">@item.SenderEmail</span>
                            </div>
                        </td>

                        <!-- Receiver -->
                        <td>
                            <div class="email-cell">
                                <span class="email-text">@item.ReceiverEmail</span>
                            </div>
                        </td>

                        <!-- Subject -->
                        <td>
                            <span class="subject-text" title="@item.Subject">@item.Subject</span>
                        </td>

                        <!-- Category -->
                        <td><span class="cat-chip">@item.MailCategoryName</span></td>

                        <!-- Spam -->
                        <td>
                            @if (item.IsSpam)
                            {
                                <span class="spam-badge is-spam">Spam</span>
                            }
                            else
                            {
                                <span class="spam-badge not-spam">Temiz</span>
                            }
                        </td>

                        <!-- Date -->
                        <td>
                            <span class="date-text">@item.CreatedDate.ToString("dd MMM yyyy")</span>
                        </td>

                        <!-- Actions -->
                        <td>
                            <div class="action-wrap">
                                <a href="#" class="action-btn" title="Detay">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                        <circle cx="12" cy="12" r="3" />
                                    </svg>
                                </a>
                                <a href="/Mail/UpdateMail/@item.MailId" class="action-btn" title="Düzenle">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                    </svg>
                                </a>
                                <a href="/Mail/DeleteMail/@item.MailId" class="action-btn del" title="Sil"
                                   onclick="return confirm('Bu maili silmek istediğinize emin misiniz?')">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="3 6 5 6 21 6" />
                                        <path d="M19 6l-1 14H6L5 6" />
                                        <path d="M10 11v6M14 11v6" />
                                        <path d="M9 6V4h6v2" />
                                    </svg>
                                </a>
                            </div>
                        </td>
                    </tr>
                }

                @if (!Model.Any())
                {
                    <tr class="empty-row">
                        <td colspan="8">Mail bulunamadı.</td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Footer -->
        <div class="mail-footer">
            <span class="page-info" id="rowCount">@Model.Count kayıt gösteriliyor</span>
            <div class="pager">
                @if ((int)ViewBag.Page > 1)
                {
                    <a href="@Url.Action("MailList", "Mail", new { page = (int)ViewBag.Page - 1, q = ViewBag.Q, spam = ViewBag.Spam })">Önceki</a>
                }
                <span>Sayfa @ViewBag.Page</span>
                @if (Model.Count == 12)
                {
                    <a href="@Url.Action("MailList", "Mail", new { page = (int)ViewBag.Page + 1, q = ViewBag.Q, spam = ViewBag.Spam })">Sonraki</a>
                }
            </div>
            <span>MailList &mdash; Admin Panel</span>
        </div>
    </div>
</div>
