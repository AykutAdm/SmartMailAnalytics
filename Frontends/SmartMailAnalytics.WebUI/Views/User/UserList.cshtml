@model List<ResultUserDto>
@{
    ViewData["Title"] = "Kullanıcılar";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap');

    :root {
        --bg: #0d0f14;
        --surface: #13161e;
        --surface-2: #1a1e2a;
        --border: #252a38;
        --accent: #4f8ef7;
        --accent-soft: rgba(79,142,247,0.08);
        --spam: #f7584f;
        --spam-soft: rgba(247,88,79,0.10);
        --muted: #4a5168;
        --text: #e2e6f0;
        --text-sub: #7b849c;
        --radius: 14px;
        --radius-sm: 8px;
    }

    .user-page {
        font-family: 'Sora', sans-serif;
        background: var(--bg);
        min-height: calc(100vh - 120px);
        padding: 8px 28px 48px;
        color: var(--text);
    }

    .user-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 28px;
        gap: 20px;
        flex-wrap: wrap;
    }

    .user-header-left h1 {
        font-size: 22px;
        font-weight: 600;
        letter-spacing: -0.3px;
        margin: 0 0 4px;
        color: var(--text);
    }

    .user-header-left p {
        font-size: 13px;
        color: var(--text-sub);
        margin: 0;
        font-weight: 300;
    }

    .badge-count {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--accent-soft);
        border: 1px solid rgba(79,142,247,0.25);
        color: var(--accent);
        font-size: 12px;
        font-weight: 500;
        padding: 3px 10px;
        border-radius: 20px;
        margin-left: 10px;
        vertical-align: middle;
        font-family: 'JetBrains Mono', monospace;
    }

    .filter-bar {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .filter-btn {
        padding: 7px 16px;
        border-radius: 20px;
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--text-sub);
        font-size: 12.5px;
        font-family: 'Sora', sans-serif;
        cursor: pointer;
        transition: all .18s;
        text-decoration: none;
        font-weight: 400;
    }

    .filter-btn:hover {
        border-color: var(--accent);
        color: var(--accent);
        background: var(--accent-soft);
    }

    .user-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
    }

    .user-table {
        width: 100%;
        border-collapse: collapse;
    }

    .user-table thead tr {
        border-bottom: 1px solid var(--border);
    }

    .user-table th {
        padding: 13px 18px;
        text-align: left;
        font-size: 11.5px;
        font-weight: 500;
        color: var(--text-sub);
        letter-spacing: 0.6px;
        text-transform: uppercase;
        background: var(--surface-2);
        white-space: nowrap;
    }

    .user-table th:first-child { padding-left: 22px; }
    .user-table th:last-child { padding-right: 22px; text-align: right; }

    .user-table tbody tr {
        border-bottom: 1px solid var(--border);
        transition: background .15s;
    }

    .user-table tbody tr:last-child { border-bottom: none; }
    .user-table tbody tr:hover { background: var(--surface-2); }

    .user-table td {
        padding: 14px 18px;
        font-size: 13.5px;
        color: var(--text);
        vertical-align: middle;
    }

    .user-table td:first-child { padding-left: 22px; }
    .user-table td:last-child { padding-right: 22px; text-align: right; }

    .id-chip {
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px;
        color: var(--text-sub);
        background: var(--surface-2);
        border: 1px solid var(--border);
        padding: 2px 8px;
        border-radius: 6px;
    }

    .name-cell {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .avatar {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 600;
        flex-shrink: 0;
        color: #fff;
    }

    .mono { font-family: 'JetBrains Mono', monospace; font-size: 12.5px; }

    .action-wrap {
        display: flex;
        gap: 6px;
        justify-content: flex-end;
    }

    .action-btn {
        width: 30px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: var(--radius-sm);
        border: 1px solid var(--border);
        background: transparent;
        color: var(--muted);
        cursor: pointer;
        transition: all .15s;
        text-decoration: none;
    }

    .action-btn:hover {
        border-color: var(--accent);
        color: var(--accent);
        background: var(--accent-soft);
    }

    .action-btn.del:hover {
        border-color: var(--spam);
        color: var(--spam);
        background: var(--spam-soft);
    }

    .empty-row td {
        text-align: center;
        padding: 48px 20px;
        color: var(--text-sub);
        font-size: 14px;
    }

    .user-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 22px;
        border-top: 1px solid var(--border);
        font-size: 12px;
        color: var(--text-sub);
        flex-wrap: wrap;
        gap: 10px;
    }

    .page-info { font-family: 'JetBrains Mono', monospace; }

    .pager {
        display: flex;
        align-items: center;
        gap: 14px;
        font-family: 'JetBrains Mono', monospace;
    }

    .pager a {
        color: var(--accent);
        text-decoration: none;
        font-size: 12px;
    }

    .pager a:hover { text-decoration: underline; }

    .pager span { color: var(--text-sub); font-size: 12px; }
</style>

<div class="user-page">
    <div class="user-header">
        <div class="user-header-left">
            <h1>
                Kullanıcılar
                <span class="badge-count">@Model.Count</span>
            </h1>
            <p>Sistemdeki kullanıcı hesapları</p>
        </div>
        <div class="filter-bar">
            <a asp-action="CreateUser" class="filter-btn" style="text-decoration:none; background:var(--accent-soft); border-color:rgba(79,142,247,0.35); color:var(--accent);">
                + Yeni kullanıcı
            </a>
        </div>
    </div>

    <div class="user-card">
        <table class="user-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>E-posta</th>
                    <th>Ad</th>
                    <th>İşlem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var avatarColors = new[] { "#4f8ef7", "#a855f7", "#3ecf8e", "#f7584f", "#f59e0b", "#06b6d4" };
                    var colorIndex = Math.Abs(item.Email.GetHashCode()) % avatarColors.Length;
                    var avatarColor = avatarColors[colorIndex];
                    var initial = item.Name.Length > 0 ? item.Name[0].ToString().ToUpper() : "?";

                    <tr>
                        <td><span class="id-chip">@item.UserId</span></td>
                        <td class="mono">@item.Email</td>
                        <td>
                            <div class="name-cell">
                                <div class="avatar" style="background:@avatarColor">@initial</div>
                                <span>@item.Name</span>
                            </div>
                        </td>
                        <td>
                            <div class="action-wrap">
                                <a asp-action="UpdateUser" asp-route-id="@item.UserId" class="action-btn" title="Düzenle">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                    </svg>
                                </a>
                                <a asp-action="DeleteUser" asp-route-id="@item.UserId" class="action-btn del" title="Sil"
                                   onclick="return confirm('Bu kullanıcıyı silmek istediğinize emin misiniz?')">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="3 6 5 6 21 6" />
                                        <path d="M19 6l-1 14H6L5 6" />
                                        <path d="M10 11v6M14 11v6" />
                                        <path d="M9 6V4h6v2" />
                                    </svg>
                                </a>
                            </div>
                        </td>
                    </tr>
                }

                @if (!Model.Any())
                {
                    <tr class="empty-row">
                        <td colspan="4">Kullanıcı bulunamadı.</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="user-footer">
            <span class="page-info">@Model.Count kayıt (bu sayfa)</span>
            <div class="pager">
                @if ((int)ViewBag.Page > 1)
                {
                    <a href="@Url.Action("UserList", "User", new { page = (int)ViewBag.Page - 1 })">Önceki</a>
                }
                <span>Sayfa @ViewBag.Page</span>
                @if (Model.Count == 12)
                {
                    <a href="@Url.Action("UserList", "User", new { page = (int)ViewBag.Page + 1 })">Sonraki</a>
                }
            </div>
            <span>UserList — Admin Panel</span>
        </div>
    </div>
</div>
