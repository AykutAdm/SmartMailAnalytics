@model List<ResultMailCategoryDto>
@{
    ViewData["Title"] = "Mail kategorileri";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap');

    :root {
        --bg: #0d0f14;
        --surface: #13161e;
        --surface-2: #1a1e2a;
        --border: #252a38;
        --accent: #4f8ef7;
        --accent-soft: rgba(79,142,247,0.08);
        --spam: #f7584f;
        --spam-soft: rgba(247,88,79,0.10);
        --muted: #4a5168;
        --text: #e2e6f0;
        --text-sub: #7b849c;
        --radius: 14px;
        --radius-sm: 8px;
    }

    .cat-page {
        font-family: 'Sora', sans-serif;
        background: var(--bg);
        min-height: calc(100vh - 120px);
        padding: 8px 28px 48px;
        color: var(--text);
    }

    .cat-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 28px;
        gap: 20px;
        flex-wrap: wrap;
    }

    .cat-header-left h1 {
        font-size: 22px;
        font-weight: 600;
        letter-spacing: -0.3px;
        margin: 0 0 4px;
        color: var(--text);
    }

    .cat-header-left p {
        font-size: 13px;
        color: var(--text-sub);
        margin: 0;
        font-weight: 300;
    }

    .badge-count {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--accent-soft);
        border: 1px solid rgba(79,142,247,0.25);
        color: var(--accent);
        font-size: 12px;
        font-weight: 500;
        padding: 3px 10px;
        border-radius: 20px;
        margin-left: 10px;
        vertical-align: middle;
        font-family: 'JetBrains Mono', monospace;
    }

    .filter-bar {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .filter-btn {
        padding: 7px 16px;
        border-radius: 20px;
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--text-sub);
        font-size: 12.5px;
        font-family: 'Sora', sans-serif;
        cursor: pointer;
        transition: all .18s;
        text-decoration: none;
        font-weight: 400;
    }

    .filter-btn:hover {
        border-color: var(--accent);
        color: var(--accent);
        background: var(--accent-soft);
    }

    .cat-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
    }

    .cat-table {
        width: 100%;
        border-collapse: collapse;
    }

    .cat-table thead tr { border-bottom: 1px solid var(--border); }

    .cat-table th {
        padding: 13px 18px;
        text-align: left;
        font-size: 11.5px;
        font-weight: 500;
        color: var(--text-sub);
        letter-spacing: 0.6px;
        text-transform: uppercase;
        background: var(--surface-2);
        white-space: nowrap;
    }

    .cat-table th:first-child { padding-left: 22px; }
    .cat-table th:last-child { padding-right: 22px; text-align: right; }

    .cat-table tbody tr {
        border-bottom: 1px solid var(--border);
        transition: background .15s;
    }

    .cat-table tbody tr:last-child { border-bottom: none; }
    .cat-table tbody tr:hover { background: var(--surface-2); }

    .cat-table td {
        padding: 14px 18px;
        font-size: 13.5px;
        color: var(--text);
        vertical-align: middle;
    }

    .cat-table td:first-child { padding-left: 22px; }
    .cat-table td:last-child { padding-right: 22px; text-align: right; }

    .id-chip {
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px;
        color: var(--text-sub);
        background: var(--surface-2);
        border: 1px solid var(--border);
        padding: 2px 8px;
        border-radius: 6px;
    }

    .name-pill {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 500;
        background: var(--surface-2);
        border: 1px solid var(--border);
        color: var(--text);
    }

    .action-wrap {
        display: flex;
        gap: 6px;
        justify-content: flex-end;
    }

    .action-btn {
        width: 30px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: var(--radius-sm);
        border: 1px solid var(--border);
        background: transparent;
        color: var(--muted);
        cursor: pointer;
        transition: all .15s;
        text-decoration: none;
    }

    .action-btn:hover {
        border-color: var(--accent);
        color: var(--accent);
        background: var(--accent-soft);
    }

    .action-btn.del:hover {
        border-color: var(--spam);
        color: var(--spam);
        background: var(--spam-soft);
    }

    .empty-row td {
        text-align: center;
        padding: 48px 20px;
        color: var(--text-sub);
        font-size: 14px;
    }

    .cat-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 22px;
        border-top: 1px solid var(--border);
        font-size: 12px;
        color: var(--text-sub);
        flex-wrap: wrap;
        gap: 10px;
    }

    .page-info { font-family: 'JetBrains Mono', monospace; }
</style>

<div class="cat-page">
    <div class="cat-header">
        <div class="cat-header-left">
            <h1>
                Mail kategorileri
                <span class="badge-count">@Model.Count</span>
            </h1>
            <p>Etiket / sınıflandırma adları</p>
        </div>
        <div class="filter-bar">
            <a asp-action="CreateMailCategory" class="filter-btn" style="text-decoration:none; background:var(--accent-soft); border-color:rgba(79,142,247,0.35); color:var(--accent);">
                + Yeni kategori
            </a>
        </div>
    </div>

    <div class="cat-card">
        <table class="cat-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Kategori adı</th>
                    <th>İşlem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span class="id-chip">@item.MailCategoryId</span></td>
                        <td><span class="name-pill">@item.Name</span></td>
                        <td>
                            <div class="action-wrap">
                                <a asp-action="UpdateMailCategory" asp-route-id="@item.MailCategoryId" class="action-btn" title="Düzenle">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                    </svg>
                                </a>
                                <a asp-action="DeleteMailCategory" asp-route-id="@item.MailCategoryId" class="action-btn del" title="Sil"
                                   onclick="return confirm('Bu kategoriyi silmek istediğinize emin misiniz?')">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="3 6 5 6 21 6" />
                                        <path d="M19 6l-1 14H6L5 6" />
                                        <path d="M10 11v6M14 11v6" />
                                        <path d="M9 6V4h6v2" />
                                    </svg>
                                </a>
                            </div>
                        </td>
                    </tr>
                }

                @if (!Model.Any())
                {
                    <tr class="empty-row">
                        <td colspan="3">Kategori bulunamadı.</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="cat-footer">
            <span class="page-info">@Model.Count kayıt</span>
            <span>MailCategory — Admin Panel</span>
        </div>
    </div>
</div>
